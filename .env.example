# Local development only.
# Copy this file to .env and replace the placeholder value.
JWT_SECRET_KEY=replace-with-a-local-development-secret

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Uncomment this to retrieve JWT-SECRET-KEY from Azure Key Vault.
# Local Azure authentication requires a successful `az login`.
# KEY_VAULT_URL=https://kv-project1-henok-2026.vault.azure.net/